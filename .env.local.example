# Supabase — get these from your project's Settings > API page
# https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: only needed for server-side admin operations (keep secret, never expose to browser)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
