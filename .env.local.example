# Supabase — get these from your project's Settings > API page
# https://app.supabase.com/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service-role key — REQUIRED for the Stripe webhook to grant paid access.
# Server-only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Absolute site URL, used for Stripe success/cancel redirects.
# In production set this to your real domain (e.g. https://yourdomain.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe — https://dashboard.stripe.com/apikeys (use test keys in development)
STRIPE_SECRET_KEY=sk_test_...
# The recurring Price you create in the Stripe dashboard (Products -> Pricing).
STRIPE_PRICE_ID=price_...
# Signing secret from the webhook endpoint you register in Stripe
# (Developers -> Webhooks). For local testing use `stripe listen`.
STRIPE_WEBHOOK_SECRET=whsec_...
